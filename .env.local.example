# Copy to .env.local and fill in values. Never commit .env.local.

# ----- Supabase (Auth + DB + Storage) -----
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Settings → Webhooks (HMAC signature)
SUPABASE_WEBHOOK_SECRET=

# Prisma → Postgres
# Prisma 7 removed `directUrl` from schema.prisma. Use the Supabase Session Pooler
# URL on port 5432 at runtime. Set DIRECT_URL when Prisma CLI operations need a
# direct non-pooled connection.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ----- AI Providers -----
# Default provider for extraction + runtime orchestrator. Supported: deepseek | groq | openai | anthropic.
# Per-tier overrides also exist: LLM_CHEAP_PROVIDER, LLM_SMART_PROVIDER.
LLM_PROVIDER=deepseek

# DeepSeek — paid, best VN→EN quality. Top up at https://platform.deepseek.com/usage
DEEPSEEK_API_KEY=

# Groq — free tier at https://console.groq.com/keys (daily token caps apply)
GROQ_API_KEY=

# OpenAI — paid; gpt-4o-mini for cheap tier, gpt-4o for smart
OPENAI_API_KEY=

# Anthropic — paid; Haiku for cheap, Sonnet for smart
ANTHROPIC_API_KEY=

# ----- Rate Limit -----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----- Analytics -----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Polar Billing (optional) -----
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
NEXT_PUBLIC_POLAR_MONTHLY_PRODUCT_ID=
NEXT_PUBLIC_POLAR_LIFETIME_PRODUCT_ID=
